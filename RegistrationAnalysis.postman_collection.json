        },
        "description": "Cenario de teste simulado: CNPJ terminando em 2 retorna APROVADO_COM_RESSALVAS (score entre 600 e 799)."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 200', function () { pm.response.to.have.status(200); });",
              "const body = pm.response.json();",
              "pm.test('Decisao APROVADO_COM_RESSALVAS', function () { pm.expect(body.decisaoFinal).to.eql('APROVADO_COM_RESSALVAS'); });",
              "pm.test('Recomendacoes presentes', function () {",
              "  pm.expect(body.explicacaoAgente).to.be.an('object');",
              "  pm.expect(body.explicacaoAgente.recomendacoes).to.be.an('array');",
              "});"
            ]
          }
        }
      ],
      "response": []
    },
    {
      "name": "03 - Reprovado (final 3)",
      "request": {
        "method": "POST",
        "header": [
          {
