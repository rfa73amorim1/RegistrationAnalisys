            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/qualificacoes?includeExplanation=true",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "qualificacoes"
          ],
          "query": [
            {
              "key": "includeExplanation",
              "value": "true"
            }
          ]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"cnpj\": \"12.345.678/0001-93\"\n}"
        },
        "description": "Cenario de teste simulado: CNPJ terminando em 3 retorna REPROVADO por CND positiva (com restricao)."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 200', function () { pm.response.to.have.status(200); });",
              "const body = pm.response.json();",
              "pm.test('Decisao REPROVADO', function () { pm.expect(body.decisaoFinal).to.eql('REPROVADO'); });",
              "pm.test('Possui ao menos uma pendencia', function () { pm.expect(body.pendencias.length).to.be.above(0); });"
            ]
          }
        }
      ],
      "response": []
    },
