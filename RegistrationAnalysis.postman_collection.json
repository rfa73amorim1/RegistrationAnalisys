{
  "info": {
    "_postman_id": "6f8bc4fe-c53a-4b8c-a970-8f2eff4f4b1a",
    "name": "RegistrationAnalysis - MVP",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Colecao de testes do MVP de qualificacao de CNPJ com fontes mockadas."
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "https://localhost:7202"
    }
  ],
  "item": [
    {
      "name": "01 - Aprovado (final 1)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/qualificacoes?includeExplanation=true",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "qualificacoes"
          ],
          "query": [
            {
              "key": "includeExplanation",
              "value": "true"
            }
          ]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"cnpj\": \"12.345.678/0001-91\"\n}"
        },
        "description": "Cenario de teste simulado: CNPJ terminando em 1 retorna APROVADO com score >= 800 e CNDs negativas."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 200', function () { pm.response.to.have.status(200); });",
              "const body = pm.response.json();",
              "pm.test('Decisao APROVADO', function () { pm.expect(body.decisaoFinal).to.eql('APROVADO'); });",
              "pm.test('Explicacao estruturada presente', function () {",
              "  pm.expect(body.explicacaoAgente).to.be.an('object');",
              "  pm.expect(body.explicacaoAgente).to.have.property('resumo');",
              "  pm.expect(body.explicacaoAgente).to.have.property('fundamentos');",
              "  pm.expect(body.explicacaoAgente).to.have.property('recomendacoes');",
              "});"
            ]
          }
        }
      ],
      "response": []
    },
    {
      "name": "02 - Aprovado com ressalvas (final 2)",
      "request": {
